#include <Keypad.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <Servo.h> 

// ---------- LCD ----------
LiquidCrystal_I2C lcd(0x20, 20, 4);

// ---------- CLAVIER ----------
const byte ROWS = 4;
const byte COLS = 3;

char keys[ROWS][COLS] = {
  {'1','2','3'},
  {'4','5','6'},
  {'7','8','9'}, 
  {'*','0','#'}
};

byte rowPins[ROWS] = {9, 8, 7, 6};
byte colPins[COLS] = {5, 4, 3};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// ---------- SERVOMOTEUR (FS5106B) ----------
Servo monServo;
const int servoPin = 2; // Fil jaune/blanc du servo sur D2

// Le FS5106B a une plage standard. 
// Ajustez ces angles si le loquet ne tourne pas assez ou trop.
const int ANGLE_VERROUILLE = 0;   
const int ANGLE_DEVERROUILLE = 90; 

// ---------- CONFIG ----------
const int nbCasiers = 3;
const int longueurCode = 6;
const int longueurAdmin = 12;
const unsigned long tempsAffichage = 1000;

const String codeAdmin = "123456789012"; 

// ---------- ETATS ----------
enum Etat { 
  CHOIX_CASIER, VALIDATION_CASIER, SAISIE_CODE, 
  SAISIE_ADMIN, ADMIN_MENU, ADMIN_CASIER 
};

Etat etat = CHOIX_CASIER;

// ---------- VARIABLES ----------
String codes[nbCasiers];
String codeSaisi = "";
String codeAdminSaisi = "";

int casierSelectionne = -1;
int adminCasierSelectionne = -1;

unsigned long tempsTouches[longueurCode];
bool masque[longueurCode];

unsigned long tempsAdmin[longueurAdmin];
bool masqueAdmin[longueurAdmin];

// ---------- FONCTIONS ----------
void genererCodeCasier(int c) {
  codes[c] = "";
  for (int i = 0; i < longueurCode; i++) {
    codes[c] += String(random(0, 10));
  }
  Serial.print("Casier ");
  Serial.print(c + 1);
  Serial.print(" : ");
  Serial.println(codes[c]);
}

void genererTousLesCodes() {
  for (int i = 0; i < nbCasiers; i++) {
    genererCodeCasier(i);
  }
}

void afficherChoixCasier() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Choisir casier:");
  lcd.setCursor(0, 1);
  lcd.print("1  2  3");
  lcd.setCursor(0, 2);
  lcd.print("* = admin");
  etat = CHOIX_CASIER;
  casierSelectionne = -1;
}

void afficherValidationCasier() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Casier ");
  lcd.print(casierSelectionne + 1);
  lcd.setCursor(0, 2);
  lcd.print("* = valider");
  lcd.setCursor(0, 3);
  lcd.print("# = annuler");
  etat = VALIDATION_CASIER;
}

void afficherSaisieCode() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Code casier ");
  lcd.print(casierSelectionne + 1);
  lcd.setCursor(0, 1);
  codeSaisi = "";
  for (int i = 0; i < longueurCode; i++) masque[i] = false;
  etat = SAISIE_CODE;
}

void afficherSaisieAdmin() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("MODE ADMIN");
  lcd.setCursor(0, 1);
  lcd.print("Code: ");
  codeAdminSaisi = "";
  for (int i = 0; i < longueurAdmin; i++) masqueAdmin[i] = false;
  etat = SAISIE_ADMIN;
}

void afficherMenuAdmin() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("ADMIN MENU");
  lcd.setCursor(0, 1);
  lcd.print("1 2 3 = casier");
  lcd.setCursor(0, 2);
  lcd.print("# = quitter");
  lcd.setCursor(0, 3);
  lcd.print("Codes visibles");
  etat = ADMIN_MENU;
  adminCasierSelectionne = -1;
}

// ---------- ADMIN CASIER ----------
void afficherAdminCasier(int casier) {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Casier ");
  lcd.print(casier + 1);
  lcd.setCursor(0, 1);
  lcd.print("Code: ");
  lcd.print(codes[casier]);
  lcd.setCursor(0, 2);
  lcd.print("* = ouvrir # = regen");
  lcd.setCursor(0, 3);
  lcd.print("0 = retour");
  etat = ADMIN_CASIER;
  adminCasierSelectionne = casier;
}

// --- FONCTION D'OUVERTURE ---
void ouvrirCasier(int casier) {
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Casier ");
  lcd.print(casier+1);
  lcd.print(" OUVERT");
  
  // Mouvement servo
  monServo.attach(servoPin, 500, 2500); // Ré-attache pour le mouvement
  monServo.write(ANGLE_DEVERROUILLE); 
  delay(500); // Temps pour que le servo atteigne la position
  
  // On laisse ouvert 4 secondes
  lcd.setCursor(0,2);
  lcd.print("Recuperer/deposer");
  delay(4000); 

  // Fermeture
  monServo.write(ANGLE_VERROUILLE);
  delay(500); // Temps pour revenir
  
  // Optionnel : Détacher le servo pour économiser l'énergie 
  // et éviter le bourdonnement si le mécanisme force un peu.
  // Ne le faites pas si la porte s'ouvre toute seule sans le couple du moteur.
  monServo.detach(); 

  genererCodeCasier(casier); 
  
  lcd.setCursor(0,3);
  lcd.print("Verrouillage OK");
  delay(1500);
}

void regenCodeCasierAdmin(int casier) {
  genererCodeCasier(casier);
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Code regenere");
  lcd.setCursor(0,1);
  lcd.print("Retour menu...");
  delay(2000);
}

// ---------- SETUP ----------
void setup() {
  Serial.begin(9600);
  randomSeed(analogRead(A0));

  // Initialisation Servo
  // Le FS5106B utilise généralement des impulsions de 500us à 2500us
  monServo.attach(servoPin, 500, 2500); 
  monServo.write(ANGLE_VERROUILLE); // Position de départ fermée
  delay(500);
  monServo.detach(); // On détache pour éviter qu'il force au repos

  genererTousLesCodes();

  lcd.init();
  lcd.backlight();
  afficherChoixCasier();
}

// ---------- LOOP ----------
void loop() {
  // Gestion affichage masqué (étoiles)
  if (etat == SAISIE_CODE) {
    for (int i = 0; i < codeSaisi.length(); i++) {
      if (!masque[i] && millis() - tempsTouches[i] >= tempsAffichage) {
        masque[i] = true;
        lcd.setCursor(i, 1);
        lcd.print('*');
      }
    }
  }

  // Gestion affichage masqué Admin
  if (etat == SAISIE_ADMIN) {
    for (int i = 0; i < codeAdminSaisi.length(); i++) {
      if (!masqueAdmin[i] && millis() - tempsAdmin[i] >= tempsAffichage) {
        masqueAdmin[i] = true;
        lcd.setCursor(6 + i, 1);
        lcd.print('*');
      }
    }
  }

  char key = keypad.getKey();
  if (!key) return;

  if (etat == CHOIX_CASIER) {
    if (key == '*') {
      afficherSaisieAdmin();
      return;
    }
    if (key >= '1' && key <= '3') {
      casierSelectionne = key - '1';
      afficherValidationCasier();
    }
  } else if (etat == VALIDATION_CASIER) {
    if (key == '*') afficherSaisieCode();
    else if (key == '#') afficherChoixCasier();
  } else if (etat == SAISIE_CODE) {
    if (key == '#') afficherChoixCasier();
    else if (key == '*') {
      lcd.clear();
      if (codeSaisi == codes[casierSelectionne]) {
        ouvrirCasier(casierSelectionne);
        afficherChoixCasier();
      } else {
        lcd.setCursor(0, 0);
        lcd.print("Code faux");
        lcd.setCursor(0, 1);
        lcd.print("Appuyez #");
        delay(2000);
        afficherChoixCasier();
      }
    } else if (codeSaisi.length() < longueurCode) {
      int pos = codeSaisi.length();
      codeSaisi += key;
      tempsTouches[pos] = millis();
      masque[pos] = false;
      lcd.setCursor(pos, 1);
      lcd.print(key);
    }
  } else if (etat == SAISIE_ADMIN) {
    if (key == '#') afficherChoixCasier();
    else if (key == '*') {
      if (codeAdminSaisi == codeAdmin) {
        afficherMenuAdmin();
      } else {
        lcd.clear();
        lcd.print("Code admin faux");
        delay(2000);
        afficherChoixCasier();
      }
    } else if (codeAdminSaisi.length() < longueurAdmin) {
      int pos = codeAdminSaisi.length();
      codeAdminSaisi += key;
      tempsAdmin[pos] = millis();
      masqueAdmin[pos] = false;
      lcd.setCursor(6 + pos, 1);
      lcd.print(key);
    }
  } else if (etat == ADMIN_MENU) {
    if (key >= '1' && key <= '3') {
      adminCasierSelectionne = key - '1';
      afficherAdminCasier(adminCasierSelectionne);
    } else if (key == '#') afficherChoixCasier();
  } else if (etat == ADMIN_CASIER) {
    if (key == '*') {
      ouvrirCasier(adminCasierSelectionne);
      afficherMenuAdmin();
    } else if (key == '#') {
      regenCodeCasierAdmin(adminCasierSelectionne);
      afficherMenuAdmin();
    } else if (key == '0') afficherMenuAdmin();
  }
}
