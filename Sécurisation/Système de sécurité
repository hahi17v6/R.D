#include <Keypad.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <Servo.h> 

// ---------- LCD ----------
LiquidCrystal_I2C lcd(0x20, 20, 4);

// ---------- CLAVIER ----------
const byte ROWS = 4;
const byte COLS = 3;

char keys[ROWS][COLS] = {
  {'1','2','3'},
  {'4','5','6'},
  {'7','8','9'}, 
  {'*','0','#'}
};

byte rowPins[ROWS] = {9, 8, 7, 6};
byte colPins[COLS] = {5, 4, 3};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// ---------- SERVOMOTEUR (FS5106B) ----------
Servo monServo;
const int servoPin = 2; // Pin Digital 2

// Angles pour le FS5106B (A ajuster si besoin)
const int ANGLE_VERROUILLE = 0;   
const int ANGLE_DEVERROUILLE = 90; 

// ---------- CONFIG ----------
const int nbCasiers = 3;
const int longueurCode = 6;
const int longueurAdmin = 12;

const String codeAdmin = "123456789012"; 

// ---------- ETATS ----------
enum Etat { 
  CHOIX_CASIER, VALIDATION_CASIER, SAISIE_CODE, 
  SAISIE_ADMIN, ADMIN_MENU, ADMIN_CASIER 
};

Etat etat = CHOIX_CASIER;

// ---------- VARIABLES ----------
String codes[nbCasiers];
String codeSaisi = "";
String codeAdminSaisi = "";

int casierSelectionne = -1;
int adminCasierSelectionne = -1;

// ---------- FONCTIONS ----------
void genererCodeCasier(int c) {
  codes[c] = "";
  for (int i = 0; i < longueurCode; i++) {
    codes[c] += String(random(0, 10));
  }
  // Debug sur le port série
  Serial.print("Casier ");
  Serial.print(c + 1);
  Serial.print(" : ");
  Serial.println(codes[c]);
}

void genererTousLesCodes() {
  for (int i = 0; i < nbCasiers; i++) {
    genererCodeCasier(i);
  }
}

void afficherChoixCasier() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Choisir casier:");
  lcd.setCursor(0, 1);
  lcd.print("1  2  3");
  lcd.setCursor(0, 2);
  lcd.print("* = admin");
  etat = CHOIX_CASIER;
  casierSelectionne = -1;
}

void afficherValidationCasier() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Casier ");
  lcd.print(casierSelectionne + 1);
  lcd.setCursor(0, 2);
  lcd.print("* = valider");
  lcd.setCursor(0, 3);
  lcd.print("# = annuler");
  etat = VALIDATION_CASIER;
}

void afficherSaisieCode() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Code casier ");
  lcd.print(casierSelectionne + 1);
  lcd.setCursor(0, 1);
  // On vide la variable de saisie
  codeSaisi = "";
  etat = SAISIE_CODE;
}

void afficherSaisieAdmin() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("MODE ADMIN");
  lcd.setCursor(0, 1);
  lcd.print("Code: ");
  codeAdminSaisi = "";
  etat = SAISIE_ADMIN;
}

void afficherMenuAdmin() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("ADMIN MENU");
  lcd.setCursor(0, 1);
  lcd.print("1 2 3 = casier");
  lcd.setCursor(0, 2);
  lcd.print("# = quitter");
  lcd.setCursor(0, 3);
  lcd.print("Codes visibles");
  etat = ADMIN_MENU;
  adminCasierSelectionne = -1;
}

// ---------- ADMIN CASIER ----------
void afficherAdminCasier(int casier) {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Casier ");
  lcd.print(casier + 1);
  lcd.setCursor(0, 1);
  lcd.print("Code: ");
  lcd.print(codes[casier]);
  lcd.setCursor(0, 2);
  lcd.print("* = ouvrir # = regen");
  lcd.setCursor(0, 3);
  lcd.print("0 = retour");
  etat = ADMIN_CASIER;
  adminCasierSelectionne = casier;
}

// --- FONCTION D'OUVERTURE ---
void ouvrirCasier(int casier) {
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Casier ");
  lcd.print(casier+1);
  lcd.print(" OUVERT");
  
  // Ouverture Servo
  monServo.attach(servoPin, 500, 2500); 
  monServo.write(ANGLE_DEVERROUILLE); 
  delay(500); 
  
  lcd.setCursor(0,2);
  lcd.print("Recuperer/deposer");
  delay(4000); // Reste ouvert 4 secondes

  // Fermeture Servo
  monServo.write(ANGLE_VERROUILLE);
  delay(500); 
  monServo.detach(); 

  genererCodeCasier(casier); 
  
  lcd.setCursor(0,3);
  lcd.print("Verrouillage OK");
  delay(1500);
}

void regenCodeCasierAdmin(int casier) {
  genererCodeCasier(casier);
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Code regenere");
  lcd.setCursor(0,1);
  lcd.print("Retour menu...");
  delay(2000);
}

// ---------- SETUP ----------
void setup() {
  Serial.begin(9600);
  randomSeed(analogRead(A0));

  // Initialisation Servo
  monServo.attach(servoPin, 500, 2500); 
  monServo.write(ANGLE_VERROUILLE); 
  delay(500);
  monServo.detach(); 

  genererTousLesCodes();

  lcd.init();
  lcd.backlight();
  afficherChoixCasier();
}

// ---------- LOOP ----------
void loop() {
  char key = keypad.getKey();
  
  if (!key) return; // Si aucune touche n'est appuyée, on ne fait rien

  // --- LOGIQUE DES ÉTATS ---

  if (etat == CHOIX_CASIER) {
    if (key == '*') {
      afficherSaisieAdmin();
      return;
    }
    if (key >= '1' && key <= '3') {
      casierSelectionne = key - '1';
      afficherValidationCasier();
    }
  } 
  
  else if (etat == VALIDATION_CASIER) {
    if (key == '*') afficherSaisieCode();
    else if (key == '#') afficherChoixCasier();
  } 
  
  else if (etat == SAISIE_CODE) {
    if (key == '#') {
      afficherChoixCasier();
    } 
    else if (key == '*') {
      // Validation du code
      lcd.clear();
      if (codeSaisi == codes[casierSelectionne]) {
        ouvrirCasier(casierSelectionne);
        afficherChoixCasier();
      } else {
        lcd.setCursor(0, 0);
        lcd.print("Code faux");
        lcd.setCursor(0, 1);
        lcd.print("Reessayer");
        delay(2000);
        afficherChoixCasier();
      }
    } 
    else if (codeSaisi.length() < longueurCode) {
      // Saisie d'un chiffre
      codeSaisi += key;
      // Affichage DIRECT du chiffre (plus d'étoiles)
      lcd.setCursor(codeSaisi.length() - 1, 1);
      lcd.print(key); 
    }
  } 
  
  else if (etat == SAISIE_ADMIN) {
    if (key == '#') afficherChoixCasier();
    else if (key == '*') {
      if (codeAdminSaisi == codeAdmin) {
        afficherMenuAdmin();
      } else {
        lcd.clear();
        lcd.print("Code admin faux");
        delay(2000);
        afficherChoixCasier();
      }
    } 
    else if (codeAdminSaisi.length() < longueurAdmin) {
      codeAdminSaisi += key;
      // Affichage DIRECT du code admin aussi
      lcd.setCursor(6 + codeAdminSaisi.length() - 1, 1);
      lcd.print(key);
    }
  } 
  
  else if (etat == ADMIN_MENU) {
    if (key >= '1' && key <= '3') {
      adminCasierSelectionne = key - '1';
      afficherAdminCasier(adminCasierSelectionne);
    } else if (key == '#') afficherChoixCasier();
  } 
  
  else if (etat == ADMIN_CASIER) {
    if (key == '*') {
      ouvrirCasier(adminCasierSelectionne);
      afficherMenuAdmin();
    } else if (key == '#') {
      regenCodeCasierAdmin(adminCasierSelectionne);
      afficherMenuAdmin();
    } else if (key == '0') afficherMenuAdmin();
  }
}
