#include "map_data_optimized.h"

// Fonction pour savoir si une coordonnée (x, y) est un mur (1) ou du vide (0)
bool getMapPixel(int x, int y) {
  if (x < 0 || x >= MAP_WIDTH || y < 0 || y >= MAP_HEIGHT) return true; // Hors limite = Obstacle

  // Comme les pixels sont "packés" par 8 dans chaque octet :
  int bytesPerRow = (MAP_WIDTH + 7) / 8;
  int byteIdx = (y * bytesPerRow) + (x / 8);
  int bitIdx = 7 - (x % 8);

  // Lecture sécurisée dans la mémoire Flash
  uint8_t byteVal = pgm_read_byte(&(map_data[byteIdx]));
  
  return (byteVal >> bitIdx) & 0x01;
}

void setup() {
  Serial.begin(115200);
  Serial.print("Carte chargee : ");
  Serial.print(MAP_WIDTH);
  Serial.print("x");
  Serial.println(MAP_HEIGHT);
}

void loop() {
  // Exemple : vérifier si le centre de la carte est un obstacle
  if (getMapPixel(MAP_WIDTH/2, MAP_HEIGHT/2)) {
    Serial.println("Obstacle detecte au centre !");
  }
  delay(1000);
}
