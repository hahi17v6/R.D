from PIL import Image

# Utilise ton image d'origine pour la précision maximale
INPUT_IMAGE = "plans bat compresser x2.png" 
OUTPUT_BIN = "map.bin"
THRESHOLD = 128 

def create_binary_map():
    img = Image.open(INPUT_IMAGE).convert('L')
    width, height = img.size
    print(f"Image détectée : {width}x{height}")

    pixels = img.load()
    
    with open(OUTPUT_BIN, "wb") as f:
        # On écrit la largeur et la hauteur sur 4 octets pour que l'ESP32 les lise
        import struct
        f.write(struct.pack('<I', width))
        f.write(struct.pack('<I', height))
        
        for y in range(height):
            current_byte = 0
            for x in range(width):
                # 1 = Mur (Noir), 0 = Vide (Blanc)
                is_wall = 1 if pixels[x, y] < THRESHOLD else 0
                bit_pos = 7 - (x % 8)
                if is_wall:
                    current_byte |= (1 << bit_pos)
                
                if (x % 8) == 7 or x == width - 1:
                    f.write(bytes([current_byte]))
                    current_byte = 0
    
    print(f"Fichier '{OUTPUT_BIN}' créé. Copie-le à la racine de ta carte Micro SD.")

create_binary_map()
