#include "SPISlave.h"

#define SPI_MISO 11
#define SPI_MOSI 12
#define SPI_SCK  13
#define SPI_CS   10

SPISlave spi;

void setup() {
  Serial.begin(9600);

  spi.setHwPins(SPI_MISO, SPI_MOSI, SPI_SCK, SPI_CS);
  spi.begin();
}

void loop() {
  if (spi.available()) {
    uint8_t data = spi.read();
    Serial.print("Recu de l'ESP32: ");
    Serial.println(data);
    spi.write(data + 1); // renvoie un octet
  }
}
